# ----------------------------------------
# Next.js 表示設定
# ----------------------------------------
# ローカル開発は空欄でOK。GitHub Pages本番は workflow 側で /nextjs を設定。
NEXT_PUBLIC_BASE_PATH=

# 静的書き出しを手元で再現する場合のみ true（通常開発は false/未設定）
STATIC_EXPORT=false

# ----------------------------------------
# Gemini API（RAG / 実験パイプライン）
# 利用箇所:
# - app/api/rag/route.ts
# - experiments/eigen_update/knowledge/build_knowledge_embeddings.py
# - experiments/eigen_update/pipeline/run_expert.py
# - experiments/eigen_update/pipeline/run_replace_expert.py
# ----------------------------------------
GOOGLE_API_KEY=

# ----------------------------------------
# OpenAI API（コメント改善スクリプト）
# 利用箇所:
# - scripts/suggest_improvements.py
# - scripts/apply_modifications.py
# ----------------------------------------
OPENAI_API_KEY=

# Googleフォーム回答スプレッドシートの公開URL（scripts/suggest_improvements.py で使用）
SPREADSHEET_URL=

# knowledge 収集時に SSL 検証を無効化する必要がある場合のみ 1（通常は 0）
ALLOW_INSECURE_SSL=0
